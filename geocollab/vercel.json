{
  "version": 2,
  "comment": "GeoCollab Vercel Deployment — full stack (Express + Socket.io)",
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["public/**", "package.json"]
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/server.js" }
  ]
}
